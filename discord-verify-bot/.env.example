# ============================================================
# ENVIRONMENT VARIABLES — Copy this to .env and fill in values
# NEVER commit .env to git — it contains your bot token!
# ============================================================

# Your Discord bot token (from Discord Developer Portal → Bot → Reset Token)
DISCORD_TOKEN=your_bot_token_here

# Your Discord Application ID (from Developer Portal → General Information)
CLIENT_ID=your_application_id_here

# Log level: error | warn | info | debug
# Use "info" in production, "debug" for troubleshooting
LOG_LEVEL=info
